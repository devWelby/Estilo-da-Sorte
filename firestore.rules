rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function role() {
      return signedIn() && currentUser().data.tipo;
    }

    function isAdmin() {
      return signedIn() && currentUser().data.tipo == 'admin';
    }

    function isSeller() {
      return signedIn() && currentUser().data.tipo == 'vendedor';
    }

    function isClient() {
      return signedIn() && currentUser().data.tipo == 'cliente';
    }

    match /usuarios/{uid} {
      allow read: if isAdmin()
        || request.auth.uid == uid
        || (isSeller() && resource.data.tipo == 'cliente');

      // Criação/alteração de usuários deve passar pela Cloud Function criarCliente
      // ou por um Admin. O Admin SDK das Functions ignora rules, então operações
      // sensíveis continuam centralizadas no backend.
      allow create, update, delete: if isAdmin();
    }

    match /sorteios/{sorteioId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /numeros/{numeroId} {
        allow read: if isAdmin()
          || isSeller()
          || (isClient() && resource.data.clienteId == request.auth.uid);

        // Escritas sensíveis de números ficam bloqueadas para o cliente.
        // Venda, pagamento e cancelamento são feitos por Cloud Functions transacionais.
        allow create, update, delete: if isAdmin();
      }

      match /participantes/{clienteId} {
        allow read: if isAdmin() || isSeller() || request.auth.uid == clienteId;
        allow write: if isAdmin();
      }
    }

    match /vendas/{vendaId} {
      allow read: if isAdmin()
        || resource.data.vendedorId == request.auth.uid
        || resource.data.clienteId == request.auth.uid;

      // Bloqueia escrita direta para evitar fraude/concorrência.
      // Use as Cloud Functions: criarVenda, confirmarPagamento e cancelarVenda.
      allow create, update, delete: if false;
    }

    match /auditoria/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
