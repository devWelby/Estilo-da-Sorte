rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profileDoc(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid));
    }

    function role() {
      return signedIn() ? profileDoc(request.auth.uid).data.tipo : '';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isSeller() {
      return role() == 'vendedor';
    }

    function isClient() {
      return role() == 'cliente';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function saleStatus(data) {
      return data.statusPagamento is string
        ? data.statusPagamento
        : (data.status is string
          ? data.status
          : (data.statusVenda is string ? data.statusVenda : ''));
    }

    function normalizeSaleStatus(value) {
      return value == 'confirmada'
        ? 'pago'
        : (value == 'recusado'
          ? 'cancelado'
          : (value == 'estornada' ? 'estornado' : value));
    }

    function isValidSaleStatus(value) {
      return normalizeSaleStatus(value) in ['pendente', 'pago', 'cancelado', 'estornado'];
    }

    function statusTransitionAllowed(beforeRaw, afterRaw) {
      let before = normalizeSaleStatus(beforeRaw);
      let after = normalizeSaleStatus(afterRaw);
      return before == after
        || (before == 'pendente' && (after == 'pago' || after == 'cancelado'))
        || (before == 'pago' && after == 'estornado');
    }

    function saleStatusFieldsConsistent(data) {
      let normalized = normalizeSaleStatus(saleStatus(data));
      return isValidSaleStatus(normalized)
        && (!(data.status is string) || normalizeSaleStatus(data.status) == normalized)
        && (!(data.statusPagamento is string) || normalizeSaleStatus(data.statusPagamento) == normalized)
        && (!(data.statusVenda is string) || normalizeSaleStatus(data.statusVenda) == normalized);
    }

    match /configuracoes/{configId} {
      allow read: if configId == 'versao_app' || signedIn();
      allow write: if isAdmin();
    }

    match /usuarios/{uid} {
      allow read: if isAdmin() || isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.tipo == 'cliente'
        && request.resource.data.nome is string
        && request.resource.data.email is string;

      allow update: if isAdmin()
        || (isOwner(uid)
          && request.resource.data.tipo == resource.data.tipo);

      allow delete: if isAdmin();

      match /pushTokens/{tokenId} {
        allow read, write: if isAdmin() || isOwner(uid);
      }
    }

    match /usuarios/{uid}/dadosPrivados/{docId} {
      allow read, write: if isAdmin() || isOwner(uid);
    }

    match /sorteios/{sorteioId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /numeros/{numeroId} {
        allow read: if isAdmin()
          || isSeller()
          || (isClient() && resource.data.clienteId == request.auth.uid);

        allow create, update, delete: if isAdmin();
      }

      match /participantes/{clienteId} {
        allow read: if isAdmin() || isSeller() || isOwner(clienteId);
        allow write: if isAdmin();
      }

      match /vendedores/{vendedorId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }

      match /metrics/{metricId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }
    }

    match /vendas/{vendaId} {
      allow read: if isAdmin()
        || (isSeller() && resource.data.vendedorId == request.auth.uid)
        || (isClient() && resource.data.clienteId == request.auth.uid);

      // Escritas de vendas sao exclusivas do backend (Cloud Functions/Admin SDK).
      // Isso evita bypass de transacao de reserva/liberacao de numeros.
      allow create, update: if false;

      allow delete: if false;
    }

    match /auditoria/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // collectionGroup('numeros')
    match /{path=**}/numeros/{numeroId} {
      allow read: if isAdmin()
        || isSeller()
        || (isClient() && resource.data.clienteId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
